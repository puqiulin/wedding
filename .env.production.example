# Add these variables to the Vercel project for production.

# Neon prod branch.
# Branch: prod (br-empty-truth-aoad996k)
DATABASE_URL=postgresql://neondb_owner:<NEON_PASSWORD>@ep-dry-sky-aoijzx0j-pooler.c-2.ap-southeast-1.aws.neon.tech/neondb?channel_binding=require&sslmode=require

# Production admin password for /admin.
ADMIN_PASSWORD=

# Cloudflare R2 prod bucket.
R2_ENDPOINT=https://<CLOUDFLARE_ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCOUNT_ID=<CLOUDFLARE_ACCOUNT_ID>
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=wedding-prod
R2_REGION=auto

# Public URL for reading files from wedding-prod.
# Use a production custom domain or r2.dev public URL after enabling public access.
NEXT_PUBLIC_R2_BASE_URL=

# AMap web key used by the venue map.
NEXT_PUBLIC_AMAP_KEY=

# Optional: required only if your AMap key has a security JS code configured.
NEXT_PUBLIC_AMAP_SECURITY_JS_CODE=

# Optional: only set true for compatible S3 endpoints that need path-style URLs.
R2_FORCE_PATH_STYLE=

# Optional: override for the bundled IP geolocation database path.
MAXMIND_DB_PATH=
