# Copy this to .env for local development.

# Neon preview branch for local development.
# Branch: preview (br-empty-mouse-ao4tfwj3)
DATABASE_URL=

# Local admin password for /admin.
ADMIN_PASSWORD=changeme

# Cloudflare R2 dev bucket.
R2_ENDPOINT=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_REGION=

# Public URL for reading files from wedding-dev.
# Use a dev custom domain or r2.dev public URL after enabling public access.
NEXT_PUBLIC_R2_BASE_URL=

# AMap web key used by the venue map.
NEXT_PUBLIC_AMAP_KEY=

# Optional: required only if your AMap key has a security JS code configured.
NEXT_PUBLIC_AMAP_SECURITY_JS_CODE=

# Optional: only set true for compatible S3 endpoints that need path-style URLs.
R2_FORCE_PATH_STYLE=

# Optional: local override for the bundled IP geolocation database path.
MAXMIND_DB_PATH=
